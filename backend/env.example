# ─── Twilio ───────────────────────────────────────────────────
# Get these from https://console.twilio.com

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio WhatsApp sender — use the Sandbox number for testing:
# whatsapp:+14155238886
# Replace with your approved business number in production:
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Set to "false" during local development (ngrok doesn't sign requests)
# Set to "true" in production
TWILIO_WEBHOOK_VALIDATE=false

# ─── Server ────────────────────────────────────────────────────
PORT=3001

# Your frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# ─── Optional: Supabase (to persist verified contacts) ─────────
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key
